<script>
    // NiceSelect gibi eklentiler varsa onları zorla tetikle
    document.addEventListener('DOMContentLoaded', function() {
        if(typeof jQuery !== 'undefined') {
            $('select').on('change', function() {
                filterAndSortTours();
            });
        }
    });

    function filterAndSortTours() {
        console.log("🚀 Motor Ateşlendi!");

        try {
            // Elementleri alırken hata payını sıfıra indiriyoruz
            const sortSelect = document.getElementById('sortSelect');
            const destSelect = document.getElementById('filterDestination');
            const dateInput = document.getElementById('filterStartDate');
            const priceSlider = document.getElementById('priceRange'); // Slider eklediysen

            const selectedSort = sortSelect ? sortSelect.value : 'default';
            const selectedDest = destSelect ? destSelect.value : 'all';
            const filterDateStr = dateInput ? dateInput.value : '';
            const maxPrice = priceSlider ? parseFloat(priceSlider.value) : 999999;

            const checkedRatings = Array.from(document.querySelectorAll('.rating-checkbox:checked')).map(cb => parseInt(cb.value));
            const checkedCities = Array.from(document.querySelectorAll('.city-checkbox:checked')).map(cb => cb.value.trim());

            const container = document.getElementById('tours-container');
            // 'tour-item' class'ını bulamazsa alternatif olarak 'blog-full' dene
            let tours = Array.from(container.querySelectorAll('.tour-item'));
            if(tours.length === 0) tours = Array.from(container.querySelectorAll('.blog-full'));

            console.log(`📦 ${tours.length} adet tur işleniyor...`);

            // 1. SIRALAMA (Sorting)
            tours.sort((a, b) => {
                let priceA = parseFloat(a.getAttribute('data-price')) || 0;
                let priceB = parseFloat(b.getAttribute('data-price')) || 0;
                let ratingA = parseFloat(a.getAttribute('data-rating')) || 0;
                let ratingB = parseFloat(b.getAttribute('data-rating')) || 0;

                if (selectedSort === 'price_asc') return priceA - priceB;
                if (selectedSort === 'price_desc') return priceB - priceA;
                if (selectedSort === 'rating') return ratingB - ratingA;
                return 0;
            });

            // 2. FİLTRELEME VE GÖSTERİM
            tours.forEach(tour => {
                // Sıralama için konteynere tekrar ekle
                container.appendChild(tour);

                let isVisible = true;
                const tourPrice = parseFloat(tour.getAttribute('data-price')) || 0;
                const tourCity = (tour.getAttribute('data-city') || "").trim();
                const tourRating = Math.floor(parseFloat(tour.getAttribute('data-rating')) || 0);
                const tourDateStr = tour.getAttribute('data-startdate');

                // Fiyat Slider Kontrolü
                if (tourPrice > maxPrice) isVisible = false;

                // Destinasyon Dropdown Kontrolü
                if (selectedDest !== 'all' && tourCity !== selectedDest) isVisible = false;

                // Şehir Checkbox Kontrolü
                if (checkedCities.length > 0 && !checkedCities.includes(tourCity)) isVisible = false;

                // Yıldız Kontrolü
                if (checkedRatings.length > 0 && !checkedRatings.includes(tourRating)) isVisible = false;

                // Tarih (±5 Gün) Kontrolü
                if (filterDateStr && isVisible && tourDateStr) {
                    let sDate = new Date(filterDateStr);
                    let tDate = new Date(tourDateStr);
                    let diffDays = Math.ceil(Math.abs(tDate - sDate) / (1000 * 60 * 60 * 24));
                    if (diffDays > 5) isVisible = false;
                }

                // --- KRİTİK NOKTA: CSS'İ EZMEK ---
                if (isVisible) {
                    tour.style.setProperty('display', 'flex', 'important');
                } else {
                    tour.style.setProperty('display', 'none', 'important');
                }
            });

            console.log("✅ Filtreleme bitti.");

        } catch (error) {
            console.error("❌ Hata:", error);
        }
    }
</script>