@using YatriiWorld.MVC.ViewModels.Tours
@model List<TourListVM>
@{
    var cityGroups = Model.Where(x => !string.IsNullOrEmpty(x.City))
                          .GroupBy(x => x.City)
                          .Select(g => new { City = g.Key, Count = g.Count() })
                          .ToList();
}
<!-- BreadCrumb Starts -->
<section class="breadcrumb-main pb-0" style="background-image: url(images/bg/bg8.jpg);">
    <div class="breadcrumb-outer pt-10">
        <div class="container">
            <div class="breadcrumb-content d-md-flex align-items-center pt-10">
                <h2 class="mb-0">Destination List</h2>
                <nav aria-label="breadcrumb">
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a href="#">Home</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Destination List</li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
    <div class="dot-overlay"></div>
</section>
<!-- BreadCrumb Ends -->

<!-- blog starts -->
<section class="blog destination-b pb-6">
    <div class="container">
        <div class="row">



            <div class="col-lg-8 col-xs-12 mb-4">
                <div class="trend-box">
                    <div class="list-results d-flex align-items-center justify-content-between mb-4">
                        <div class="list-results-sort">
                            <p class="m-0">Showing 1-@Model.Count() of @Model.Count() results</p>
                        </div>
                        <div class="click-menu d-flex align-items-center justify-content-between">
                            <div class="change-list f-active mr-2"><a href="destination-list.html"><i class="fa fa-bars"></i></a></div>
                            <div class="change-grid"><a href="destination-grid.html"><i class="fa fa-th"></i></a></div>
                            <div class="sortby d-flex align-items-center justify-content-between ml-2">
                                <select class="niceSelect" id="sortSelect" onchange="sortTours(this.value)">
                                    <option value="default">Sort By</option>
                                    <option value="rating">Average rating</option>
                                    <option value="price_asc">Price: low to high</option>
                                    <option value="price_desc">Price: high to low</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div id="tours-container" class="row">
                        @foreach (var tour in Model)
                        {
                            <div class="blog-full d-flex justify-content-around mb-4 tour-item w-100"
                                 data-price="@tour.Price"
                                 data-rating="@tour.Rating"
                                 data-city="@tour.City"
                                 data-startdate="@tour.StartDate.ToString("yyyy-MM-dd")">

                                <div class="row w-100">
                                    @* İndirim vs. varsa buraya ekleyebilirsin, statik 10% OFF koydum şimdilik *@
                                    <div class="ribbon ribbon-top-left"><span>10% OFF</span></div>

                                    <div class="col-lg-5 col-md-4 col-xs-12 blog-height">
                                        <div class="blog-image">
                                            @{
                                                var mainImage = tour.Images?.FirstOrDefault(x => x.IsMain)?.ImageUrl;
                                                var imagePath = string.IsNullOrEmpty(mainImage) ? "/assets/images/trending/trending1.jpg" : "/assets/" + mainImage.TrimStart('/');
                                            }
                                            <a href="@Url.Action("TourDetails", "Home", new { id = tour.Id })" style="background-image: url('@imagePath');"></a>
                                        </div>
                                    </div>

                                    <div class="col-lg-7 col-md-8 col-xs-12">
                                        <div class="blog-content p-0">
                                            <h4 class="mb-1">
                                                <a href="@Url.Action("TourDetails", "Home", new { id = tour.Id })">@tour.Title</a>
                                            </h4>

                                            <div class="trend-tags">
                                                <button type="button" onclick="event.stopPropagation(); addToWishlist(@tour.Id);" style="background: none; border: none; padding: 0; cursor: pointer;">
                                                    <i class="fa fa-heart" style="color: #f34e4e;"></i>
                                                </button>
                                            </div>

                                            <div class="rating pb-1">
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    if (i <= tour.Rating)
                                                    {
                                                        <span class="fa fa-star checked" style="color: #ffc107;"></span>
                                                    }
                                                    else if (i - 0.5 <= tour.Rating)
                                                    {
                                                        <span class="fa fa-star-half-alt checked" style="color: #ffc107;"></span>
                                                    }
                                                    else
                                                    {
                                                        <span class="fa fa-star" style="color: #dfe6e9;"></span>
                                                    }
                                                }
                                            </div>

                                            <p class="mb-2 pink"><i class="fa fa-map-marker mr-1"></i> @tour.City, @tour.Country</p>

                                            <p class="mb-2 border-t pt-2">
                                                @(tour.Description?.Length > 100 ? tour.Description.Substring(0, 100) + "..." : tour.Description)
                                            </p>

                                            <div class="deal-price">
                                                <p class="price mb-0">From <span>$@tour.Price</span>/ @tour.DurationInDays Gün</p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="text-center mt-4">
                        <a href="#" class="nir-btn">Load More <i class="fa fa-long-arrow-alt-right"></i></a>
                    </div>
                </div>
            </div>









  
<div class="col-lg-4 col-xs-12 mb-4">
                <div class="sidebar-sticky">

                    <div class="sidebar-item mb-4">
                        <form class="form-content">
                            <h4 class="title white">Find The Places</h4>
                            <div class="row">

                                <div class="col-lg-12">
                                    <div class="form-group">
                                        <label class="white">Your Destination</label>
                                        <div class="input-box">
                                            <i class="flaticon-placeholder"></i>
                                            <select class="niceSelect" id="filterDestination" onchange="filterAndSortTours()">
                                                <option value="all">Where are you going?</option>
                                                @foreach (var item in cityGroups)
                                                {
                                                    <option value="@item.City">@item.City</option>
                                                }
                                            </select>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-lg-12 mt-3">
                                    <div class="form-group">
                                        <label class="white">Start Date (± 5 Days)</label>
                                        <div class="input-box">
                                            <i class="flaticon-calendar"></i>
                                            <input type="date" id="filterStartDate" class="form-control" onchange="filterAndSortTours()" style="background: transparent; color: inherit; border: 1px solid #eee; border-radius: 5px; padding-left: 45px; height: 50px;">
                                        </div>
                                    </div>
                                </div>

                            </div>
                        </form>
                    </div>

                    <div class="list-sidebar">
                        
                        <div class="sidebar-item">
                            <h4>Star Rating</h4>
                            @for (int i = 5; i >= 1; i--)
                            {
                                <div class="pretty p-default p-thick p-pulse">
                                    <input type="checkbox" class="rating-checkbox" value="@i" onchange="filterAndSortTours()" />
                                    <div class="state">
                                        <label>
                                            <span class="star-rating">
                                                @for (int j = 0; j < i; j++)
                                                {
                                                    <span class="fa fa-star checked" style="color:#ffc107;"></span>
                                                }
                                            </span>
                                        </label>
                                    </div>
                                </div>
                            }
                      
                        </div>
                        <div class="sidebar-item mb-4">
                            <h4 class="title">Price Range</h4>
                            <div class="range-slider">
                                <input type="range" class="form-control-range custom-slider" id="priceRange"
                                       min="0" max="10000" step="100" value="10000"
                                       oninput="document.getElementById('priceVal').innerText = this.value + '$'"
                                       onchange="filterAndSortTours()">
                                <div class="d-flex justify-content-between mt-2">
                                    <span>0$</span>
                                    <span id="priceVal" class="font-weight-bold text-danger">10000$</span>
                                </div>
                            </div>
                        </div>

                        <style>
                            .custom-slider {
                                width: 100%;
                                accent-color: #f34e4e; 
                                height: 8px;
                            }
                        </style>

                        <div class="sidebar-item">
                            <h4>City</h4>
                            @foreach (var item in cityGroups)
                            {
                                <div class="pretty p-default p-thick p-pulse">
                                    <input type="checkbox" class="city-checkbox" value="@item.City" onchange="filterAndSortTours()" />
                                    <div class="state">
                                        <label>
                                            @item.City <span class="number">@item.Count</span>
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>

                    </div>




                </div>
            </div>


            <div class="col-lg-8 col-xs-12 mb-4">
                <div class="trend-box">
                    
                    <div class="list-results d-flex align-items-center justify-content-between mb-4">
                        <div class="list-results-sort">
                            <p class="m-0">Showing @Model.Count() results</p>
                        </div>
                        <div class="click-menu d-flex align-items-center justify-content-between">
                            <div class="sortby d-flex align-items-center justify-content-between ml-2">
                                <select class="niceSelect" id="sortSelect" onchange="filterAndSortTours()">
                                    <option value="default">Sort By</option>
                                    <option value="rating">Average rating</option>
                                    <option value="price_asc">Price: low to high</option>
                                    <option value="price_desc">Price: high to low</option>
                                </select>
                            </div>
                        </div>
                    </div>

                  
                </div>
            </div>

        </div>



        </div>
    </div>
</section>
<!-- blog Ends -->



