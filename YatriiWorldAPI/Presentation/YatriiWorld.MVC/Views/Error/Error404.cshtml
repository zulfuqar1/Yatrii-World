@{

    Layout = "_Layout";
}



<!-- BreadCrumb Starts -->
<section class="breadcrumb-main pb-0" style="background-image: url(images/bg/bg8.jpg);">
    <div class="breadcrumb-outer pt-10">
        <div class="container">
            <div class="breadcrumb-content d-md-flex align-items-center pt-10">
  
            </div>
        </div>
    </div>
    <div class="dot-overlay"></div>
</section>
<!-- BreadCrumb Ends -->



<!-- Preloader Ends -->
<section class="error overflow-hidden" style="padding: 100px 0;">
    <div class="container">
        <div class="error-content text-center">
            <h3 class="mb-2">Oops! Page Not Found</h3>

            <img src="~/assets/images/404-1.svg" alt="404 Hatası" class="mb-4" style="max-width: 400px;">

            <h2 class="mb-0 navy">Sorry, the route you're looking for is either unavailable or may have been changed.</h2>

            <div class="newsletter-form w-75 mx-auto mt-3">
            </div>

            <div class="error-btn mt-4">
                <a asp-controller="Home" asp-action="Index" class="nir-btn mr-2">HOME</a>
            </div>
        </div>
    </div>
</section>