    <script>
        function addToBasket(productId, quantity) {
            $.ajax({
                url: '/Basket/AddToBasket',
                type: 'POST',
                data: {
                    productId: productId,
                    quantity: quantity
                },
                success: function (response) {
                    if (response.success) {
                        // Layout'taki sepet ikonunun sayısını günceller
                        $('.cart-label').text(response.cartCount);

                        // Kullanıcıya şık bir bildirim gösterebilirsin (SweetAlert vb.)
                        alert(response.message);
                    } else {
                        alert("Hata: " + response.message);
                    }
                },
                error: function () {
                    alert("İşlem sırasında bir hata oluştu. Lütfen giriş yaptığınızdan emin olun.");
                }
            });
        }
    </script>


