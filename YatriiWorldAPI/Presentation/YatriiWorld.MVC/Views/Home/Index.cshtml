
@model List<TourListVM>

    <!-- banner starts -->
    <section class="banner overflow-hidden">
        <div class="slider video-slider">
            <div class="banner-outer">
                <div class="video-banner">
                    <video autoplay muted loop id="vid">
                        <source src="~/assets/images/tour.mp4" type="video/mp4">
                    </video>
                    <div class="overlay"></div>
                </div>
                <div class="swiper-content">
                    <h4 class="white">Amazing Places</h4>
                    <h1 class="white mb-4">Explore Your Life Travel Where You Want</h1>
                <a asp-controller="Shop" asp-action="TourShop" class="per-btn">
                    <span class="white">Discover</span>
                    <i class="fa fa-arrow-right white"></i>
                </a>
                </div>
            </div>
        </div>
    </section>
    <!-- banner ends -->
    <!-- form starts -->
    <section class="about-us p-0">
        <div class="container">
            <div class="about-image-box">
                <div class="row">
                    <div class="col-lg-7 col-sm-12">
                        <div class="about-content pt-9">
                            <h4 class="mb-1 blue font-weight-normal">About Yatriiworld</h4>
                            <h2>We're Truely Dedicated To Make Your Travel Experience As Much As Simple And Fun As Possible</h2>
                            <p class="mb-0">Top Tour Operators and Travel Agency. We offering in total 793 tours and holidays throughout the world. Combined we have received 1532 customer reviews and an average rating of 5 out of 5 stars. <br><br>Travel has helped us to understand the meaning of life and it has helped us become better people. Each time we travel, we see the world with new eyes.</p>
                        </div>
                    </div>
                    <div class="col-lg-5 col-sm-12">
                        <!-- form main starts -->
                        <div class="form-main">
                            <div class="form-content w-100 p-0">
                                <h3 class="form-title text-center m-0 p-3 white">Find a Places</h3>
                                <div class="form-content-inner p-4">
                                    <div class="row">
                                
                                        <div class="col-lg-12">
                                            <div class="form-group m-0 w-100 text-center">
                                            <a asp-controller="Shop" asp-action="TourShop" class="nir-btn"><i class="fa fa-search"></i> Check Availability</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- form main ends -->
                    </div>
                </div>
            </div>

            <!-- Counter -->
            <div class="counter-main pt-6">
                <div class="counter text-center">
                    <div class="row">
                        <div class="col-lg-3 col-md-6 col-sm-6 mb-4">
                            <div class="counter-item bg-navy">
                                <i class="fa fa-users white mb-1"></i>
                                <h3 class="value mb-0 white d-inline ml-2">100</h3>
                                <h4 class="m-0 white">Happy Customers</h4>
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6 col-sm-6 mb-4">
                            <div class="counter-item bg-navy">
                                <i class="fa fa-plane white mb-1"></i>
                                <h3 class="value mb-0 white d-inline ml-2">50</h3>
                                <h4 class="m-0 white">Amazing Tours </h4>
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6 col-sm-6 mb-4">
                            <div class="counter-item bg-navy">
                                <i class="fa fa-chart-bar white mb-1"></i>
                                <h3 class="value mb-0 white d-inline ml-2">372</h3>
                                <h4 class="m-0 white">In Business</h4>
                            </div>
                        </div>

                        <div class="col-lg-3 col-md-6 col-sm-6 mb-4">
                            <div class="counter-item bg-navy">
                                <i class="fa fa-support white mb-1"></i>
                                <h3 class="value mb-0 white d-inline ml-2">523</h3>
                                <h4 class="m-0 white">Support Cases </h4>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
            <!-- End Counter -->

        </div>
    </section>
    <!-- form ends -->

    <!-- top destination starts -->
<section class="top-destination overflow-hidden bg-navy pt-9">
    <div class="container">
        <div class="section-title section-title-w text-center mb-5 pb-2 w-50 mx-auto">
            <h2 class="m-0 white"><span>Best Holidays Trips</span> In The World</h2>
            <p class="mb-0 white">Travel has helped us to understand the meaning of life and it has helped us become better people. Each time we travel, we see the world with new eyes.</p>
        </div>

        <div class="desti-inner">
            <div class="row d-flex align-items-center">

                @{
                    int count = 0;
                }
                @foreach (TourListVM tour in Model.Take(7))
                {
                    string colClass = "col-lg-4 col-md-6 p-1"; 
                    int mod = count % 7;

                    if (mod >= 3 && mod < 6)
                    {
                        colClass = "col-lg-3 col-md-6 p-1"; 
                    }
                    else if (mod == 6)
                    {
                        colClass = "col-lg-3 col-md-12 p-1"; 
                    }

                    <div class="@colClass">
                        <div class="desti-image" style="height: 100%;">
                            @{
                                var mainImage = tour.Images?.FirstOrDefault(x => x.IsMain)?.ImageUrl;
                            }
                            <img src="@(string.IsNullOrEmpty(mainImage) ? "/assets/images/destination/destination9.jpg" : "/assets/" + mainImage.TrimStart('/'))"
                                 alt="@tour.Title"
                                 style="width: 100%; height: 100%; object-fit: cover; min-height: 250px;">

                            <div class="desti-content">
                                <div class="rating mb-1">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= tour.Rating)
                                        {
                                            <span class="fa fa-star checked" style="color: #ffc107;"></span>
                                        }
                                        else if (i - 0.5 <= tour.Rating)
                                        {
                                            <span class="fa fa-star-half-alt checked" style="color: #ffc107;"></span>
                                        }
                                        else
                                        {
                                            <span class="fa fa-star" style="color: #dfe6e9;"></span>
                                        }
                                    }
                                </div>
                                <h4 class="white mb-0">@tour.Title</h4>
                            </div>
                            <div class="desti-overlay">
                                <a asp-controller="Home" asp-action="TourDetails" asp-route-id="@tour.Id" class="nir-btn">
                                    <span class="white">Book Now</span>
                                    <i class="fa fa-arrow-right white pl-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                    count++;
                }

            </div>
        </div>
    </div>
    <div id="particles-js"></div>
</section>
    <!-- top destination ends -->
    
    
    <!-- Trending Starts -->
    <section class="trending destination-b pb-6 pt-9">
        <div class="container">
            <div class="section-title text-center mb-5 pb-2 w-50 mx-auto">
                <h2 class="m-0">Perfect <span>Tour Packages</span></h2>
                <p class="mb-0">Travel has helped us to understand the meaning of life and it has helped us become better people. Each time we travel, we see the world with new eyes.</p>
            </div>
            <div class="trend-box">
                <div class="row team-slider">

                @foreach (TourListVM tour in Model)
                {
                    <div class="col-lg-4 col-md-6 col-xs-12 mb-4">
            
                        <div class="trend-item position-relative" style="min-width: 330px; min-height: 450px; background: #fff; border-radius: 10px; overflow: hidden;">

                         
                            <a asp-controller="Home" asp-action="TourDetails" asp-route-id="@tour.Id"
                               style="text-decoration: none; color: inherit; display: block;">

                                <div class="trend-image" style="height: 220px; overflow: hidden;">
                                    @{
                                        var mainImage = tour.Images?.FirstOrDefault(x => x.IsMain)?.ImageUrl;
                                    }
                                    <img src="@(string.IsNullOrEmpty(mainImage) ? "/assets/images/trending/trending1.jpg" : "/assets/" + mainImage.TrimStart('/'))"
                                         alt="@tour.Title"
                                         style="width: 100%; height: 100%; object-fit: cover;">
                                </div>

                                <div class="trend-content-main">
                                    <div class="trend-content" style="padding: 15px;">
                                        <h6 class="font-weight-normal text-muted"><i class="fa fa-map-marker-alt"></i> @tour.City @tour.Country</h6>
                                        <h4 style="min-height: 30px; margin-bottom: 10px; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; color: #222;">
                                            @tour.Title
                                        </h4>

                                        <div class="rating-main d-flex align-items-center">
                                            <div class="rating">
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    if (i <= @tour.Rating)
                                                    {
                                                        @* Dolu Yıldız *@
                                                        <span class="fa fa-star checked" style="color: #ffc107;"></span>
                                                    }
                                                    else if (i - 0.5 <= @tour.Rating)
                                                    {
                                                        @* Buçuklu Yıldız *@
                                                        <span class="fa fa-star-half-alt checked" style="color: #ffc107;"></span>
                                                    }
                                                    else
                                                    {
                                                        @* Boş Yıldız *@
                                                        <span class="fa fa-star" style="color: #dfe6e9;"></span>
                                                    }
                                                }
                                            </div>
                                            <span class="ml-2 text-muted">@tour.Rating</span>
                                        </div>
                                    </div>

                                    <div class="trend-last-main" style="padding: 15px;">
                                        <p class="mb-0 trend-para" style="height: 75px; overflow: hidden; color: #666;">
                                            @(tour.Description?.Length > 75 ? tour.Description.Substring(0, 75) + "..." : tour.Description)
                                        </p>
                                        <div class="trend-last d-flex align-items-center justify-content-between">
                                            <p class="mb-0 white"><i class="fa fa-clock-o" aria-hidden="true"></i> @tour.DurationInDays Gün</p>
                                            <div class="trend-price">
                                                <p class="price white mb-0">From <span>$@tour.Price</span></p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </a>

                          
                            <div class="trend-tags" style="position: absolute; top: 15px; right: 15px; z-index: 10;">
                                <button type="button" onclick="event.stopPropagation(); addToWishlist(@tour.Id);"
                                        style="background: rgba(255,255,255,0.8); border: none; border-radius: 50%; width: 40px; height: 40px; cursor: pointer; display: flex; align-items: center; justify-content: center;">
                                    <i class="flaticon-like" style="color: #f34e4e; font-size: 18px;"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                }
</div>

        </div>
    </section>
    <!-- Trending Ends -->
    
    
  






<section class="latest-tour pb-5 pt-0">
    <div class="container">
        <div class="section-title text-center mb-5 pb-2 w-50 mx-auto">
            <h2 class="m-0">Amazing <span>Latest Tour</span></h2>
            <p class="mb-0">Travel has helped us to understand the meaning of life and it has helped us become better people. Each time we travel, we see the world with new eyes.</p>
        </div>
        <div class="tour-box">
            <div class="row">

                @if (Model != null && Model.Any())
                {
                    @* Sadece ilk 3 tur *@
                    @foreach (var tour in Model.Take(3))
                    {
                        <div class="col-lg-4 col-md-6 col-xs-12 mb-4">
                            <div class="tour-item">
                                <div class="tour-image">
                                    @{
                                        var mainImage = tour.Images?.FirstOrDefault(x => x.IsMain)?.ImageUrl ?? tour.ImageUrl;
                                    }
                                    @* Sadece resmin boyutunu sabitledik, orijinal tasarıma dokunmadık *@
                                    <img src="@(string.IsNullOrEmpty(mainImage) ? "/assets/images/destination/destination4.jpg" : "/assets/" + mainImage.TrimStart('/'))"
                                         alt="@tour.Title"
                                         style="width: 100%; height: 400px; object-fit: cover;">
                                </div>

                                <div class="tour-content">
                                    <div class="rating-main d-flex align-items-center mb-1">
                                        <div class="rating">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                if (i <= tour.Rating)
                                                {
                                                    <span class="fa fa-star checked" style="color: #ffc107;"></span>
                                                }
                                                else if (i - 0.5 <= tour.Rating)
                                                {
                                                    <span class="fa fa-star-half-alt checked" style="color: #ffc107;"></span>
                                                }
                                                else
                                                {
                                                    <span class="fa fa-star white"></span>
                                                }
                                            }
                                        </div>
                                        <span class="ml-2 white">@tour.ReviewCount Reviews</span>
                                    </div>

                                    <h3 class="mb-1">
                                        <a asp-controller="Home" asp-action="TourDetails" asp-route-id="@tour.Id" class="white">@tour.Title</a>
                                    </h3>

                                    <div class="user-main d-flex align-items-center justify-content-between mb-2 pb-2 border-b">
                                        <p class="white mb-0 mr-"><i class="fa fa-clock white mr-1"></i> @tour.DurationInDays days</p>
                                        <p class="white mb-0"><i class="fa fa-user-plus white mr-1"></i> @tour.Capacity</p>
                                    </div>

                                    <p class="white mb-3">
                                        @(tour.Description?.Length > 75 ? tour.Description.Substring(0, 75) + "..." : tour.Description)
                                    </p>

                                    <a asp-controller="Home" asp-action="TourDetails" asp-route-id="@tour.Id" class="nir-btn" tabindex="0">View More</a>
                                </div>

                                <div class="tour-tag">
                                    <span class="new-price white">$@tour.Price</span>
                                </div>
                                <div class="color-overlay"></div>
                            </div>
                        </div>
                    }
                }

            </div>
        </div>
    </div>
</section>
 
    


@section Scripts {
    <script src="~/assets/js/plugin.js"></script>

    <script src="~/assets/js/main.js"></script>

    <script>
   
        if (typeof l === 'undefined') {
            var l = function() { return { left: 0 }; };
        }

        $(document).ready(function(){
            if($('.team-slider').length > 0) {
               
            }
        });
    </script>
}