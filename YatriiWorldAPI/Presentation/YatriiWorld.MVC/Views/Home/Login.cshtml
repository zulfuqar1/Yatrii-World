@using YatriiWorld.MVC.ViewModels.LoginRegister
@model LoginVM
@{
    ViewData["Title"] = "Login";
}

<section class="breadcrumb-main pb-0" style="background-image: url(/assets/images/bg/bg8.jpg);">
    <div class="breadcrumb-outer pt-10">
        <div class="container">
            <div class="breadcrumb-content d-md-flex align-items-center pt-10">
                <h2 class="mb-0">Login</h2>
                <nav aria-label="breadcrumb">
                    <ul class="breadcrumb">
                        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
                        <li class="breadcrumb-item active" aria-current="page">My Login</li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
    <div class="dot-overlay"></div>
</section>
<section class="login">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-8 col-sm-12 mx-auto">
                <div class="login-content border p-4 shadow-sm" style="background: #fff; border-radius: 10px;">
                    <h4 class="text-center mb-4">Hello! Sign into your account</h4>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <div asp-validation-summary="All" class="text-danger"></div>
                        </div>
                    }

                    <form asp-controller="Home" asp-action="Login" method="post">
                        @Html.AntiForgeryToken()

                        <div class="form-group mb-3">
                            <label asp-for="UsernameOrEmail">Email Address / Username</label>
                            <input asp-for="UsernameOrEmail" class="form-control" placeholder="Enter email or username">
                            <span asp-validation-for="UsernameOrEmail" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Password">Password</label>
                            <input asp-for="Password" class="form-control" placeholder="Enter your password">
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="form-group form-checkbox text-center mb-3 d-flex justify-content-between align-items-center">
                            <div>
                                <input asp-for="RememberMe" class="mr-1">
                                <label asp-for="RememberMe" class="mb-0">Remember Me</label>
                            </div>
                            <a href="#" class="yellow" style="color: #ffb100;">Forgot password?</a>
                        </div>

                        <div class="form-btn text-center mt-4">
                            <button type="submit" class="nir-btn w-100 mb-3" style="cursor: pointer; border: none;">LOGIN</button>
                            <p class="">Need an Account? <a asp-controller="Auth" asp-action="Register" class="text-primary">Create your account</a></p>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</section>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}