<!DOCTYPE html>
<html lang="en">

<head>
    <!-- Required meta tags -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Majestic Admin</title>
    <!-- plugins:css -->
    <link rel="stylesheet" href="~/admin/vendors/mdi/css/materialdesignicons.min.css">
    <link rel="stylesheet" href="~/admin/vendors/base/vendor.bundle.base.css">
    <!-- endinject -->
    <!-- plugin css for this page -->
    <link rel="stylesheet" href="~/admin/vendors/datatables.net-bs4/dataTables.bootstrap4.css">
    <!-- End plugin css for this page -->
    <!-- inject:css -->
    <link rel="stylesheet" href="~/admin/css/style.css">
    <!-- endinject -->
    <link rel="shortcut icon" href="~/admin/images/favicon.png" />
</head>
<body>
    <div class="container-scroller">
     
        <!-- partial:partials/_navbar.html -->
        <nav class="navbar col-lg-12 col-12 p-0 fixed-top d-flex flex-row">
            <div class="navbar-brand-wrapper d-flex justify-content-center">
                <div class="navbar-brand-inner-wrapper d-flex justify-content-between align-items-center w-100">
                    <a class="navbar-brand brand-logo" href="index.html"><img src="~/admin/images/logo.svg" alt="logo" /></a>
                    <a class="navbar-brand brand-logo-mini" href="index.html"><img src="~/admin/images/logo-mini.svg" alt="logo" /></a>
                    <button class="navbar-toggler navbar-toggler align-self-center" type="button" data-toggle="minimize">
                        <span class="mdi mdi-sort-variant"></span>
                    </button>
                </div>
            </div>

            <div class="navbar-menu-wrapper d-flex align-items-center justify-content-end">

                <div class="register-login d-flex align-items-center" style="position: relative; z-index: 1050; margin-right: 15px;">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <a href="javascript:void(0);"
                           onclick="event.stopPropagation(); document.getElementById('userDropdownMenu').classList.toggle('show');"
                           class="d-flex align-items-center"
                           style="text-decoration: none;">

                            <img src="/assets/@(User.FindFirst("UserProfilePicture")?.Value ?? "images/default-avatar.png")"
                                 style="width: 35px; height: 35px; border-radius: 50%; object-fit: cover;"
                                 onerror="this.onerror=null; this.src='/assets/images/default-avatar.png';">

                            <div class="d-flex flex-column ml-2">
                                <span style="color: #333; font-weight: bold; font-size: 14px; line-height: 1;">
                                    @User.Identity.Name
                                </span>
                            </div>

                            <i class="mdi mdi-chevron-down ml-2" style="color: #333; font-size: 18px;"></i>
                        </a>

                        <div id="userDropdownMenu" class="dropdown-menu shadow-sm" style="position: absolute; top: 100%; right: 0; border-radius: 8px; border: 1px solid rgba(0,0,0,.1); min-width: 150px; margin-top: 15px; padding: 5px 0; background-color: white;">

                            <a class="dropdown-item py-2 px-3 d-flex align-items-center"
                               asp-controller="User"
                               asp-action="Profile"
                               style="color: #333 !important; font-size: 13px; font-weight: 500; display: block; text-decoration: none;">
                                <i class="mdi mdi-account mr-2" style="font-size: 16px; color: #777;"></i> Profile
                            </a>

                            @if (User.IsInRole("Admin"))
                            {
                                <a class="dropdown-item py-2 px-3 d-flex align-items-center" asp-area="Admin" asp-controller="Home" asp-action="Index" style="color: #007bff !important; font-size: 13px; font-weight: 500; display: block; text-decoration: none;">
                                    <i class="mdi mdi-settings mr-2" style="font-size: 16px; color: #007bff;"></i> Admin Panel
                                </a>
                            }

                            <div class="dropdown-divider" style="margin: 5px 0;"></div>

                            <a class="dropdown-item py-2 px-3 d-flex align-items-center" asp-controller="Home" asp-action="Logout" style="color: red !important; font-size: 13px; font-weight: 500; display: block; text-decoration: none;">
                                <i class="mdi mdi-logout mr-2" style="font-size: 16px; color: red;"></i> Logout
                            </a>

                        </div>
                    }
                    else
                    {
                        <a asp-controller="Home" asp-action="Register" class="mr-3" style="color: #333; font-weight: bold; text-decoration: none;">
                            <i class="mdi mdi-account-plus mr-1"></i> Register
                        </a>
                        <a asp-controller="Home" asp-action="Login" style="color: #333; font-weight: bold; text-decoration: none;">
                            <i class="mdi mdi-login mr-1"></i> Login
                        </a>
                    }
                </div>
                <button class="navbar-toggler navbar-toggler-right d-lg-none align-self-center" type="button" data-toggle="offcanvas">
                    <span class="mdi mdi-menu"></span>
                </button>
            </div>
        </nav>
        <!-- partial -->


        <div class="container-fluid page-body-wrapper">
            <!-- partial:partials/_sidebar.html -->

















            <nav class="sidebar sidebar-offcanvas" id="sidebar">
                <ul class="nav">

                    <li class="nav-item">
                        <a class="nav-link" asp-area="Admin" asp-controller="Home" asp-action="Index">
                            <i class="mdi mdi-home menu-icon"></i>
                            <span class="menu-title">Admin Home</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-area="Admin" asp-controller="Product" asp-action="Index">
                            <i class="mdi mdi-cart menu-icon"></i>
                            <span class="menu-title">Products</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-area="Admin" asp-controller="ProductTag" asp-action="Index">
                            <i class="mdi mdi-tag menu-icon"></i>
                            <span class="menu-title">Product Tags</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-area="Admin" asp-controller="Tour" asp-action="Index">
                            <i class="mdi mdi-airplane menu-icon"></i>
                            <span class="menu-title">Tours</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-area="Admin" asp-controller="TourTag" asp-action="Index">
                            <i class="mdi mdi-tag-multiple menu-icon"></i>
                            <span class="menu-title">Tour Tags</span>
                        </a>
                    </li>

                </ul>
            </nav>
            <!-- partial -->
            <div class="main-panel">


                <div class="content-wrapper">

        @RenderBody()




                </div>
                <!-- content-wrapper ends -->
                <!-- partial:partials/_footer.html -->
                <footer class="footer">
                    
                </footer>
                <!-- partial -->
            </div>
            <!-- main-panel ends -->
        </div>
        <!-- page-body-wrapper ends -->
    </div>
    <!-- container-scroller -->
    <!-- plugins:js -->
    <script src="~/admin/vendors/base/vendor.bundle.base.js"></script>
    <!-- endinject -->
    <!-- Plugin js for this page-->
    <script src="~/admin/vendors/chart.js/Chart.min.js"></script>
    <script src="~/admin/vendors/datatables.net/jquery.dataTables.js"></script>
    <script src="~/admin/vendors/datatables.net-bs4/dataTables.bootstrap4.js"></script>
    <!-- End plugin js for this page-->
    <!-- inject:js -->
    <script src="~/admin/js/off-canvas.js"></script>
    <script src="~/admin/js/hoverable-collapse.js"></script>
    <script src="~/admin/js/template.js"></script>
    <!-- endinject -->
    <!-- Custom js for this page-->
    <script src="~/admin/js/dashboard.js"></script>
    <script src="~/admin/js/data-table.js"></script>
    <script src="~/admin/js/jquery.dataTables.js"></script>
    <script src="~/admin/js/dataTables.bootstrap4.js"></script>
    <!-- End custom js for this page-->

    <script src="~/admin/js/jquery.cookie.js" type="text/javascript"></script>
</body>

</html>

<script>
    window.addEventListener('click', function(e){
        var dropdown = document.getElementById('userDropdownMenu');
        if (dropdown && !dropdown.contains(e.target)){
            dropdown.classList.remove('show');
        }
    });
</script>