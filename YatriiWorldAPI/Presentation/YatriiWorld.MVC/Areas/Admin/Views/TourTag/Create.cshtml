@model YatriiWorld.MVC.ViewModels.Tours.TourTagCreateVM

<div class="row">
    <div class="col-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Create Tour Tag</h4>
                <p class="card-description">
                    Yeni bir tur etiketi eklemek için formu doldurun.
                </p>

                <form class="forms-sample" asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-group">
                        <label asp-for="Name">Tag Name</label>
                        <input asp-for="Name" class="form-control" placeholder="Örn: Doğa Yürüyüşü">
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-primary me-2">Submit</button>
                    <a asp-action="Index" class="btn btn-light">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>